{
  "productName": "Cadastre Finder",
  "version": "1.0.0",
  "identifier": "fr.antsch.cadastre-finder",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8000",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cadastre Finder",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "scheme": "http",
          "domain": "127.0.0.1",
          "windows": ["main"],
          "plugins": ["opener"],
          "enableTauriApi": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
